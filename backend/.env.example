PORT=4000
# Local MongoDB: mongodb://127.0.0.1:27017/entreskill
# MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster-url>/entreskill?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/entreskill
# Generate a strong random value for production, e.g. `openssl rand -hex 32`
JWT_SECRET=replace_this_with_a_long_random_secret
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
